{
  "rewrites": [
    { "source": "/auth/login",    "destination": "/api/login" },
    { "source": "/auth/callback", "destination": "/api/callback" },
    { "source": "/api/logout",         "destination": "/api/session?ruta=logout" },
    { "source": "/api/me",             "destination": "/api/session?ruta=me" },
    { "source": "/manifest.json",  "destination": "/public/manifest.json" },
    { "source": "/favicon.svg",    "destination": "/public/favicon.svg" },
    { "source": "/styles.css",     "destination": "/public/styles.css" },
    { "source": "/logo.webp",      "destination": "/public/logo.webp" },
    { "source": "/icon-192.png",   "destination": "/public/icon-192.png" },
    { "source": "/icon-512.png",   "destination": "/public/icon-512.png" },
    { "source": "/icon-maskable-512.png", "destination": "/public/icon-maskable-512.png" },
    { "source": "/sw.js",          "destination": "/public/sw.js" },
    { "source": "/robots.txt",     "destination": "/public/robots.txt" },
    { "source": "/sitemap.xml",    "destination": "/public/sitemap.xml" },
    { "source": "/js/:file",       "destination": "/public/js/:file" },
    { "source": "/",              "destination": "/public/index.html" },
    { "source": "/index.html",    "destination": "/public/index.html" },
    { "source": "/dashboard.html",       "destination": "/public/dashboard.html" },
    { "source": "/registro-civil.html",  "destination": "/public/registro-civil.html" },
    { "source": "/banco.html",           "destination": "/public/banco.html" },
    { "source": "/admin-banco.html",     "destination": "/public/admin-banco.html" },
    { "source": "/tienda.html",          "destination": "/public/tienda.html" },
    { "source": "/inventario.html",      "destination": "/public/inventario.html" },
    { "source": "/mercado.html",         "destination": "/public/mercado.html" },
    { "source": "/concesionario.html",   "destination": "/public/concesionario.html" },
    { "source": "/mis-autos.html",       "destination": "/public/mis-autos.html" },
    { "source": "/admin-tienda.html",    "destination": "/public/admin-tienda.html" },
    { "source": "/apuestas.html",        "destination": "/public/apuestas.html" },
    { "source": "/casino.html",          "destination": "/public/casino.html" },
    { "source": "/ruleta.html",         "destination": "/public/ruleta.html" },
    { "source": "/admin-casino.html",    "destination": "/public/admin-casino.html" },
    { "source": "/error-403.html",       "destination": "/public/error-403.html" },
    { "source": "/error-404.html",       "destination": "/public/error-404.html" },
    { "source": "/perfil-publico.html",  "destination": "/public/perfil-publico.html" },
    { "source": "/empresas.html",        "destination": "/public/empresas.html" },
    { "source": "/logros.html",          "destination": "/public/logros.html" },
    { "source": "/admin-empresas.html",  "destination": "/public/admin-empresas.html" },
    { "source": "/panel-admin.html",     "destination": "/public/panel-admin.html" },
    { "source": "/staff-panel.html",     "destination": "/public/staff-panel.html" },
    { "source": "/comisaria.html",       "destination": "/public/comisaria.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
        }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    },
    {
      "source": "/styles.css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    },
    {
      "source": "/(icon-192.png|icon-512.png|icon-maskable-512.png|logo.webp|favicon.svg)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000, immutable" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    }
  ]
}
